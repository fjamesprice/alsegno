# Copy to .env and fill in. The real .env is gitignored. `install.sh` / `install.ps1`
# generate this file for you (with a random SESSION_SECRET) — you rarely edit it by hand.

# Port the app listens on.
PORT=3458

# Bind address.
#   127.0.0.1  → this machine only (the right choice behind a reverse proxy like nginx).
#   0.0.0.0    → reachable from other devices on your network (e.g. review a mix from a phone).
# Only expose 0.0.0.0 on a network you trust — there is no HTTPS on the bare port.
HOST=127.0.0.1

# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Username of the first/owner admin, seeded on first run. The first successful login for this
# account sets its password permanently (trust-on-first-use). Lowercased automatically.
# install.sh / install.ps1 default this to your OS account name; set it to whatever you like.
ADMIN_USER=admin

# How people reach the app, set by the installer's menu (the start-* launchers act on it):
#   local       → this computer only (HOST stays 127.0.0.1).
#   lan         → other devices on your network (HOST=0.0.0.0; plain HTTP, trusted networks only).
#   cloudflare  → on launch, run a free Cloudflare quick tunnel and print a public https link
#                 (downloads ./bin/cloudflared the first time; a fresh link each start, no account).
#   tailscale   → on launch, publish over Tailscale Funnel for a stable public https link
#                 (needs Tailscale installed + signed in + Funnel enabled).
SHARE=local

# Set ONLY if a reverse proxy (nginx/Caddy) sits in front of the app — the number of proxy hops
# (usually 1). It makes the app use the real client IP (from X-Forwarded-For) for rate limiting and
# Secure-cookie detection. LEAVE UNSET for direct LAN (HOST=0.0.0.0) or share-tunnel exposure: there
# a client could forge X-Forwarded-For, so the app instead keys on the unspoofable socket address.
# TRUST_PROXY=1

# Minimum password length enforced when a password is set or changed (default 8).
# MIN_PASSWORD_LEN=8

# Upload safety caps (prevent a disk-fill DoS).
#   UPLOAD_FREE_SPACE_MARGIN_MB  headroom to always keep free; an upload that would dip below it is
#                                rejected (default 500).
#   MAX_UPLOAD_BYTES_GB          total cap on stored media; 0 = unlimited (default 0).
#   MAX_REVISIONS_PER_TRACK      max revisions a single track can hold (default 100).
# UPLOAD_FREE_SPACE_MARGIN_MB=500
# MAX_UPLOAD_BYTES_GB=0
# MAX_REVISIONS_PER_TRACK=100

# Hard wall-clock ceiling (seconds) on each ffmpeg/ffprobe child, so one bad media file can't wedge
# the processing queue (default 900 = 15 min).
# FFMPEG_TIMEOUT_SEC=900

# Where data and media live. Optional — default to ./data and ./uploads next to server.js.
# Override to relocate the SQLite DB and uploaded audio (also handy for throwaway test instances).
# DATA_DIR=./data
# UPLOADS_DIR=./uploads
