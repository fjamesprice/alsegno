# Copy to .env and fill in. The real .env is gitignored. `install.sh` / `install.ps1`
# generate this file for you (with a random SESSION_SECRET) — you rarely edit it by hand.

# Port the app listens on.
PORT=3458

# Bind address.
#   127.0.0.1  → this machine only (the right choice behind a reverse proxy like nginx).
#   0.0.0.0    → reachable from other devices on your network (e.g. review a mix from a phone).
# Only expose 0.0.0.0 on a network you trust — there is no HTTPS on the bare port.
HOST=127.0.0.1

# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Username of the first/owner admin, seeded on first run. The first successful login for this
# account sets its password permanently (trust-on-first-use). Lowercased automatically.
# install.sh / install.ps1 default this to your OS account name; set it to whatever you like.
ADMIN_USER=admin

# Where data and media live. Optional — default to ./data and ./uploads next to server.js.
# Override to relocate the SQLite DB and uploaded audio (also handy for throwaway test instances).
# DATA_DIR=./data
# UPLOADS_DIR=./uploads
