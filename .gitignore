.claude/settings.local.json
.claude/*.lock

# ── Logs / OS / editor cruft ───────────────────────────
*.log
npm-debug.log*
.DS_Store
Thumbs.db
*.swp

# ── Local docs / planning (kept on disk, not in the repo) ──
app-stuff.md
CLAUDE.md
ROADMAP.md
roadmap2.md
